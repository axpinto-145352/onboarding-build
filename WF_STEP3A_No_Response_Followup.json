            "index": 0
          }
        ]
      ]
    },
    "Extract Contact Data": {
      "main": [
        [
          {
            "node": "Loop Over Contacts",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Loop Over Contacts": {
      "main": [
        [],
        [
          {
            "node": "Add to Prosp.ai Follow-Up Campaign",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Add to Prosp.ai Follow-Up Campaign": {
      "main": [
        [
          {
            "node": "Update Notion (Follow-Up Sequence)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Update Notion (Follow-Up Sequence)": {
      "main": [
        [
          {
            "node": "Wait",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Wait": {
      "main": [
        [
          {
            "node": "Loop Over Contacts",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1",
    "availableInMCP": true,
    "timeSavedMode": "fixed",
    "callerPolicy": "workflowsFromSameOwner"
  },
  "versionId": "step5a-v1-0",
  "meta": {
    "templateCredsSetupCompleted": false
  },
