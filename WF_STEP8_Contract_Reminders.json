    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "=Friendly reminder: Invoice for {{ $json.company }}",
        "message": "=<p>Hey {{ $json.first_name }},</p><p>Just a quick reminder that we have an outstanding invoice for the {{ $json.company }} project. If you've already sent payment, please disregard this message!</p><p>If you have any questions about the invoice, just reply to this email.</p><p>Cheers,<br>Anthony<br>Veteran Vectors</p>",
        "options": {
