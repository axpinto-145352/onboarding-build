{
  "name": "Onboarding WF8 \u2014 Contract & Invoice Reminders (Daily \u2192 Every 3 Days)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hour": 9,
              "triggerAtHour": 9
            }
          ]
        }
      },
      "id": "step6-node-1",
      "name": "Every Day 9 AM",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [250, 300],
      "notes": "Runs daily at 9 AM. The Calculate Days & Tier code node determines whether to send a reminder today (daily for first 7 days, then every 3 days)."
    },
    {
      "id": "step6-node-2",
      "name": "Query Notion: Unsigned Contracts",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2,
      "position": [470, 300],
      "credentials": {
        "notionApi": { "id": "YOUR_NOTION_CRED_ID", "name": "Notion account" }
      },
      "parameters": {
        "resource": "databasePage",
        "operation": "getAll",
        "databaseId": { "__rl": true, "value": "YOUR_NOTION_CONTACTS_DB_ID", "mode": "id" },
        "returnAll": true,
        "filterType": "manual",
        "filters": {
          "conditions": [
            {
              "key": "Status|select",
              "condition": "string:equals",
              "selectValue": "Contract Sent"
            },
            {
              "key": "Last Contact Date|date",
              "condition": "dateTime:onOrBefore",
              "dateValue": "={{ $now.minus({days: 1}).toISODate() }}"
            }
          ]
        },
        "options": { "simple": false }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            {
              "leftValue": "={{ $json.id || '' }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "notEmpty", "singleValue": true }
            }
          ]
        },
        "looseTypeValidation": true,
        "options": {}
      },
      "id": "step6-node-3",
      "name": "Any Unsigned?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [690, 300]
    },
    {
      "parameters": {
        "jsCode": "const results = $input.all().map(i => i.json).filter(p => p.id);\nconst now = new Date();\n\nreturn results.map(page => {\n  const props = page.properties;\n  const name = props['Name']?.title?.[0]?.text?.content || '';\n  const email = props['Email']?.email || '';\n  const company = props['Company']?.rich_text?.[0]?.text?.content || '';\n  const lastContact = props['Last Contact Date']?.date?.start || '';\n  const daysSinceSent = lastContact ? Math.floor((now - new Date(lastContact)) / 86400000) : 0;\n\n  let reminderType = 'skip'; // default: don't send today\n  if (daysSinceSent >= 30) {\n    reminderType = 'expire';\n  } else if (daysSinceSent <= 7) {\n    reminderType = 'gentle'; // daily for first week\n  } else if (daysSinceSent % 3 === 0) {\n    reminderType = 'escalation'; // every 3 days after week 1\n  }\n\n  return { json: {\n    notion_page_id: page.id, name, email, company,\n    first_name: name.split(' ')[0],\n    days_since_sent: daysSinceSent,\n    reminder_type: reminderType,\n    last_contact: lastContact\n  }};\n});"
      },
      "id": "step6-node-4",
      "name": "Calculate Days & Tier",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [910, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            {
              "leftValue": "={{ $json.reminder_type }}",
              "rightValue": "skip",
              "operator": { "type": "string", "operation": "notEquals" }
            }
          ]
        },
        "looseTypeValidation": true,
        "options": {}
      },
      "id": "step6-node-5",
      "name": "Filter Skip Days",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1130, 300],
      "notes": "Filters out contacts where reminder_type is 'skip' (days 8-29 that aren't divisible by 3)."
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "step6-node-6",
      "name": "Loop Over Contacts",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1350, 300]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
                "conditions": [
                  {
                    "leftValue": "={{ $json.reminder_type }}",
                    "rightValue": "gentle",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputLabel": "Gentle Reminder"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
                "conditions": [
                  {
                    "leftValue": "={{ $json.reminder_type }}",
                    "rightValue": "escalation",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputLabel": "Escalation"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
                "conditions": [
                  {
                    "leftValue": "={{ $json.reminder_type }}",
                    "rightValue": "expire",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputLabel": "Auto-Expire"
            }
          ]
        },
        "options": {}
      },
      "id": "step6-node-7",
      "name": "Route by Reminder Type",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [1570, 300]
    },
    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "=Quick follow-up on your Veteran Vectors proposal, {{ $json.first_name }}",
        "message": "=<p>Hey {{ $json.first_name }},</p><p>Just wanted to follow up on the Statement of Work we sent over. Let me know if you have any questions or want to hop on a quick call to discuss.</p><p>Looking forward to working together!</p><p>Cheers,<br>Anthony<br>Veteran Vectors</p>",
        "options": {
          "ccList": "anthony@veteranvectors.io"
        }
      },
      "id": "step6-node-8a",
      "name": "Send Gentle Reminder",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [1790, 160],
      "credentials": {
        "gmailOAuth2": { "id": "r13jnGsjwNOqcBvt", "name": "VV Gmail account" }
      }
    },
    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "=Checking in on your project - {{ $json.company }}",
        "message": "=<p>Hey {{ $json.first_name }},</p><p>I wanted to reach out again regarding our Statement of Work for {{ $json.company }}. It's been {{ $json.days_since_sent }} days since we sent it over.</p><p>I understand things get busy \u2014 if you need any changes to the scope, timeline, or pricing, I'm happy to adjust. Just let me know what works best for you.</p><p>If now isn't the right time, no worries at all. Just want to make sure we're on the same page.</p><p>Cheers,<br>Anthony<br>Veteran Vectors</p>",
        "options": {
          "ccList": "anthony@veteranvectors.io"
        }
      },
      "id": "step6-node-8b",
      "name": "Send Escalation Email",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [1790, 320],
      "credentials": {
        "gmailOAuth2": { "id": "r13jnGsjwNOqcBvt", "name": "VV Gmail account" }
      }
    },
    {
      "id": "step6-node-8c",
      "name": "Auto-Expire in Notion",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2,
      "position": [1790, 480],
      "credentials": {
        "notionApi": { "id": "YOUR_NOTION_CRED_ID", "name": "Notion account" }
      },
      "notes": "After 30 days with no signed contract, auto-expires the lead to 'Declined' in Notion.",
      "parameters": {
        "resource": "databasePage",
        "operation": "update",
        "pageId": "={{ $json.notion_page_id }}",
        "propertiesUi": {
          "propertyValues": [
            { "key": "Status|select", "selectValue": "Declined" },
            { "key": "Last Contact Date|date", "dateValue": "={{ $now.toISO() }}", "includeTime": true }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "step6-node-9",
      "name": "Log Reminder in Notion",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2,
      "position": [2010, 240],
      "credentials": {
        "notionApi": { "id": "YOUR_NOTION_CRED_ID", "name": "Notion account" }
      },
      "notes": "Updates Last Contact Date to track when reminders were sent (prevents duplicate reminders).",
      "parameters": {
        "resource": "databasePage",
        "operation": "update",
        "pageId": "={{ $json.notion_page_id }}",
        "propertiesUi": {
          "propertyValues": [
            { "key": "Last Contact Date|date", "dateValue": "={{ $now.toISO() }}", "includeTime": true }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "step6-node-10",
      "name": "Query Notion: Unpaid Invoices",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2,
      "position": [470, 600],
      "credentials": {
        "notionApi": { "id": "YOUR_NOTION_CRED_ID", "name": "Notion account" }
      },
      "notes": "Queries contacts with Status='Project Started' and Invoice Paid checkbox unchecked. Requires adding 'Invoice Paid' checkbox property to Notion Contacts DB.",
      "parameters": {
        "resource": "databasePage",
        "operation": "getAll",
        "databaseId": { "__rl": true, "value": "YOUR_NOTION_CONTACTS_DB_ID", "mode": "id" },
        "returnAll": true,
        "filterType": "manual",
        "filters": {
          "conditions": [
            {
              "key": "Status|select",
              "condition": "string:equals",
              "selectValue": "Project Started"
            },
            {
              "key": "Invoice Paid|checkbox",
              "condition": "boolean:equals",
              "booleanValue": false
            }
          ]
        },
        "options": { "simple": false }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            {
              "leftValue": "={{ $json.id || '' }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "notEmpty", "singleValue": true }
            }
          ]
        },
        "looseTypeValidation": true,
        "options": {}
      },
      "id": "step6-node-11",
      "name": "Any Unpaid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [690, 600]
    },
    {
      "parameters": {
        "jsCode": "const results = $input.all().map(i => i.json).filter(p => p.id);\nconst now = new Date();\n\nreturn results.map(page => {\n  const props = page.properties;\n  const name = props['Name']?.title?.[0]?.text?.content || '';\n  const email = props['Email']?.email || '';\n  const company = props['Company']?.rich_text?.[0]?.text?.content || '';\n  const lastContact = props['Last Contact Date']?.date?.start || '';\n  const daysSinceInvoice = lastContact ? Math.floor((now - new Date(lastContact)) / 86400000) : 0;\n\n  let reminderType = 'skip';\n  if (daysSinceInvoice <= 7) {\n    reminderType = 'gentle_invoice'; // daily for first week\n  } else if (daysSinceInvoice % 3 === 0) {\n    reminderType = 'urgent_invoice'; // every 3 days after week 1\n  }\n\n  return { json: {\n    notion_page_id: page.id, name, email, company,\n    first_name: name.split(' ')[0],\n    days_since_invoice: daysSinceInvoice,\n    reminder_type: reminderType,\n    last_contact: lastContact\n  }};\n});"
      },
