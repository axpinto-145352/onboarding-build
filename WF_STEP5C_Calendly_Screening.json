{
  "name": "WF STEP5C - Calendly Discovery Call Screening + Approval",
  "nodes": [
    {
      "parameters": {
        "authentication": "oAuth2",
        "events": ["invitee.created"]
      },
      "id": "step5c-node-1",
      "name": "Calendly Trigger",
      "type": "n8n-nodes-base.calendlyTrigger",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "step5c-calendly-trigger",
      "credentials": {
        "calendlyOAuth2Api": {
          "id": "Htykkb3r14siqEFc",
          "name": "VV - Calendly account"
        }
      },
      "notes": "Triggers when a new invitee books a discovery call via Calendly."
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "extract-name",
              "name": "name",
              "value": "={{ $json.payload.name || $json.payload.invitee?.name || '' }}",
              "type": "string"
            },
            {
              "id": "extract-email",
              "name": "email",
              "value": "={{ $json.payload.email || $json.payload.invitee?.email || '' }}",
              "type": "string"
            },
            {
              "id": "extract-first-name",
              "name": "first_name",
              "value": "={{ ($json.payload.name || $json.payload.invitee?.name || '').split(' ')[0] }}",
              "type": "string"
            },
            {
              "id": "extract-event-uuid",
              "name": "event_uuid",
              "value": "={{ $json.payload.event.split('/').pop() }}",
              "type": "string"
            },
            {
              "id": "extract-revenue",
              "name": "monthly_revenue",
              "value": "={{ $json.payload.questions_and_answers.find(q => q.question.toLowerCase().includes('revenue'))?.answer || 'Unknown' }}",
              "type": "string"
            },
            {
              "id": "extract-employees",
              "name": "employees",
              "value": "={{ $json.payload.questions_and_answers.find(q => q.question.toLowerCase().includes('employee') || q.question.toLowerCase().includes('team size'))?.answer || 'Unknown' }}",
              "type": "string"
            },
            {
              "id": "extract-company",
              "name": "company",
              "value": "={{ $json.payload.questions_and_answers.find(q => q.question.toLowerCase().includes('company'))?.answer || 'Unknown' }}",
              "type": "string"
            },
            {
              "id": "extract-budget",
              "name": "budget",
              "value": "={{ $json.payload.questions_and_answers.find(q => q.question.toLowerCase().includes('budget'))?.answer || 'Unknown' }}",
              "type": "string"
            },
            {
              "id": "extract-decision-maker",
              "name": "decision_maker",
              "value": "={{ $json.payload.questions_and_answers.find(q => q.question.toLowerCase().includes('decision maker'))?.answer || 'Unknown' }}",
              "type": "string"
            },
            {
              "id": "extract-pain-points",
              "name": "pain_points",
              "value": "={{ $json.payload.questions_and_answers.find(q => q.question.toLowerCase().includes('pain') || q.question.toLowerCase().includes('challenge'))?.answer || 'Unknown' }}",
              "type": "string"
            },
            {
              "id": "extract-event-url",
              "name": "event_url",
              "value": "={{ $json.payload.uri || '' }}",
              "type": "string"
            },
            {
              "id": "extract-scheduled-time",
              "name": "scheduled_time",
              "value": "={{ $json.payload.scheduled_event?.start_time || $json.payload.event_start_time || '' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "step5c-node-2",
      "name": "Extract Booking Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [470, 300],
      "notes": "Extracts all relevant data from Calendly booking: name, email, revenue, employees, company, budget, decision maker status, pain points."
    },
    {
      "parameters": {
        "jsCode": "// Parse monthly revenue and check if between $0-$5,000\nconst revenueStr = $json.monthly_revenue || '';\n\n// Extract numeric value from revenue answer\nconst numericMatch = revenueStr.replace(/[^0-9.,kKmM]/g, '');\nlet revenueValue = 0;\n\nif (revenueStr.toLowerCase().includes('under') || revenueStr.includes('<')) {\n  // Answers like 'Under $5,000' or '<$5K'\n  const num = revenueStr.replace(/[^0-9.,]/g, '');\n  revenueValue = parseFloat(num) || 0;\n} else if (revenueStr.toLowerCase().includes('k')) {\n  revenueValue = parseFloat(revenueStr.replace(/[^0-9.,]/g, '')) * 1000;\n} else if (revenueStr.toLowerCase().includes('m')) {\n  revenueValue = parseFloat(revenueStr.replace(/[^0-9.,]/g, '')) * 1000000;\n} else {\n  revenueValue = parseFloat(revenueStr.replace(/[^0-9.,]/g, '')) || 0;\n}\n\n// Check if revenue is between $0 and $5,000\nconst isLowRevenue = revenueValue >= 0 && revenueValue <= 5000;\n\n// Also flag if answer directly indicates low revenue\nconst lowRevenueKeywords = ['0-5', '0 - 5', 'under 5', 'less than 5', '<5', '$0', 'none', 'pre-revenue', 'startup'];\nconst containsLowKeyword = lowRevenueKeywords.some(kw => revenueStr.toLowerCase().includes(kw));\n\nreturn [{\n  json: {\n    ...$json,\n    revenue_parsed: revenueValue,\n    needs_approval: isLowRevenue || containsLowKeyword,\n    revenue_flag: isLowRevenue || containsLowKeyword ? 'LOW ($0-$5K)' : 'QUALIFIED'\n  }\n}];"
      },
      "id": "step5c-node-3",
      "name": "Parse Revenue & Check Threshold",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [690, 300],
      "notes": "Parses monthly revenue from Calendly answer. Checks if between $0-$5,000/month. Handles various answer formats (Under $5K, <$5,000, etc.)."
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            {
              "leftValue": "={{ $json.needs_approval }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true" }
            }
          ]
        },
        "looseTypeValidation": true,
        "options": {}
      },
      "id": "step5c-node-4",
      "name": "Revenue $0-$5K?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [910, 300],
      "notes": "Routes to approval email if revenue is $0-$5K/month. Otherwise, auto-qualifies and updates Notion."
    },
    {
      "parameters": {
        "sendTo": "anthony@veteranvectors.io",
        "subject": "=Approval Needed: Discovery Call - {{ $json.name }} ({{ $json.company }})",
        "message": "=<div style=\"font-family:Arial,sans-serif;max-width:600px;margin:0 auto;color:#333;\">\n  <div style=\"background-color:#1a1a2e;padding:24px 40px;text-align:center;border-radius:8px 8px 0 0;\">\n    <span style=\"color:#4dd0e1;font-size:22px;font-weight:bold;\">DISCOVERY CALL APPROVAL</span>\n  </div>\n  <div style=\"padding:40px;background:#fff;\">\n    <p style=\"font-size:16px;\">A discovery call has been booked that <strong>needs your approval</strong>.</p>\n    <p style=\"color:#e74c3c;font-weight:bold;\">Revenue Flag: {{ $json.revenue_flag }} ({{ $json.monthly_revenue }})</p>\n    \n    <table style=\"width:100%;border-collapse:collapse;margin:20px 0;\">\n      <tr><td style=\"padding:8px;border-bottom:1px solid #eee;font-weight:bold;\">Name</td><td style=\"padding:8px;border-bottom:1px solid #eee;\">{{ $json.name }}</td></tr>\n      <tr><td style=\"padding:8px;border-bottom:1px solid #eee;font-weight:bold;\">Email</td><td style=\"padding:8px;border-bottom:1px solid #eee;\">{{ $json.email }}</td></tr>\n      <tr><td style=\"padding:8px;border-bottom:1px solid #eee;font-weight:bold;\">Company</td><td style=\"padding:8px;border-bottom:1px solid #eee;\">{{ $json.company }}</td></tr>\n      <tr><td style=\"padding:8px;border-bottom:1px solid #eee;font-weight:bold;\">Monthly Revenue</td><td style=\"padding:8px;border-bottom:1px solid #eee;\">{{ $json.monthly_revenue }}</td></tr>\n      <tr><td style=\"padding:8px;border-bottom:1px solid #eee;font-weight:bold;\">Employees</td><td style=\"padding:8px;border-bottom:1px solid #eee;\">{{ $json.employees }}</td></tr>\n      <tr><td style=\"padding:8px;border-bottom:1px solid #eee;font-weight:bold;\">Budget</td><td style=\"padding:8px;border-bottom:1px solid #eee;\">{{ $json.budget }}</td></tr>\n      <tr><td style=\"padding:8px;border-bottom:1px solid #eee;font-weight:bold;\">Decision Maker?</td><td style=\"padding:8px;border-bottom:1px solid #eee;\">{{ $json.decision_maker }}</td></tr>\n      <tr><td style=\"padding:8px;border-bottom:1px solid #eee;font-weight:bold;\">Pain Points</td><td style=\"padding:8px;border-bottom:1px solid #eee;\">{{ $json.pain_points }}</td></tr>\n      <tr><td style=\"padding:8px;border-bottom:1px solid #eee;font-weight:bold;\">Scheduled</td><td style=\"padding:8px;border-bottom:1px solid #eee;\">{{ $json.scheduled_time }}</td></tr>\n    </table>\n    \n    <div style=\"text-align:center;margin:30px 0;\">\n      <a href=\"YOUR_N8N_WEBHOOK_BASE_URL/webhook/calendly-approval?action=approve&event_uuid={{ $json.event_uuid }}&email={{ encodeURIComponent($json.email) }}&name={{ encodeURIComponent($json.name) }}\" style=\"display:inline-block;background:#27ae60;color:#fff;text-decoration:none;font-weight:bold;font-size:16px;padding:14px 36px;border-radius:6px;margin:0 10px;\">APPROVE</a>\n      <a href=\"YOUR_N8N_WEBHOOK_BASE_URL/webhook/calendly-approval?action=disapprove&event_uuid={{ $json.event_uuid }}&email={{ encodeURIComponent($json.email) }}&name={{ encodeURIComponent($json.name) }}\" style=\"display:inline-block;background:#e74c3c;color:#fff;text-decoration:none;font-weight:bold;font-size:16px;padding:14px 36px;border-radius:6px;margin:0 10px;\">DISAPPROVE</a>\n    </div>\n  </div>\n  <div style=\"background:#1a1a2e;padding:20px;text-align:center;border-radius:0 0 8px 8px;\">\n    <p style=\"margin:0;color:#888;font-size:12px;\">Veteran Vectors Onboarding Pipeline</p>\n  </div>\n</div>",
        "options": {}
      },
      "id": "step5c-node-5",
      "name": "Send Approval Email",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [1130, 200],
      "credentials": {
        "gmailOAuth2": {
          "id": "r13jnGsjwNOqcBvt",
          "name": "VV Gmail account"
        }
      },
      "notes": "Sends approval email to Anthony with all lead details and Approve/Disapprove buttons. Replace YOUR_N8N_WEBHOOK_BASE_URL with your n8n instance URL."
    },
    {
