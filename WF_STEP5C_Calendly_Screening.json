      "position": [910, 520],
      "notes": "Updates Notion to 'Meeting Booked' when Anthony approves."
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "=<html><body style='font-family:Arial;text-align:center;padding:60px;'><h1 style='color:#27ae60;'>Approved!</h1><p>The discovery call with {{ $('Approval Webhook').item.json.query.name }} will proceed as scheduled.</p><p>Notion CRM has been updated.</p></body></html>",
        "options": {
          "responseHeaders": {
            "entries": [{ "name": "Content-Type", "value": "text/html" }]
          }
        }
      },
      "id": "step5c-node-11a",
      "name": "Respond Approved",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1130, 520]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.notion.com/v1/databases/YOUR_NOTION_CONTACTS_DB_ID/query",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Notion-Version", "value": "2022-06-28" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"filter\": {\n    \"property\": \"Email\",\n    \"email\": {\n      \"equals\": \"{{ decodeURIComponent($json.query.email) }}\"\n    }\n  }\n}",
        "options": {}
      },
      "id": "step5c-node-9b",
      "name": "Find Contact (Disapprove)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [690, 720]
    },
    {
      "parameters": {
        "sendTo": "={{ decodeURIComponent($('Approval Webhook').item.json.query.email) }}",
        "subject": "=Thanks for your interest, {{ decodeURIComponent($('Approval Webhook').item.json.query.name).split(' ')[0] }}",
        "message": "=<div style=\"font-family:Arial,sans-serif;max-width:600px;margin:0 auto;color:#333;font-size:16px;line-height:1.7;\">\n  <div style=\"background-color:#1a1a2e;padding:24px 40px;text-align:center;border-radius:8px 8px 0 0;\">\n    <span style=\"color:#4dd0e1;font-size:22px;font-weight:bold;letter-spacing:1px;\">VETERAN VECTORS</span>\n  </div>\n  <div style=\"padding:40px;background:#fff;\">\n    <p>Hey <strong>{{ decodeURIComponent($('Approval Webhook').item.json.query.name).split(' ')[0] }}</strong>,</p>\n    <p>It's Anthony from Veteran Vectors.</p>\n    <p>I took a look at your application and at this point, our services aren't quite the right fit for where your business is currently. We typically work with companies at a different stage of growth.</p>\n    <p>Out of respect for your time, I've gone ahead and cancelled our upcoming call so you don't have to worry about it.</p>\n    <p>That said, I still want to make sure you get something valuable out of this. I put together a complete guide on implementing automations in your business — it's free and packed with stuff you can use right away:</p>\n    <p style=\"text-align:center;padding:16px 0;\">\n      <a href=\"https://drive.google.com/file/d/1Rghj0-doawvR9jCAPts0oLncSMB4Du5N/view?usp=sharing\" style=\"display:inline-block;background-color:#4dd0e1;color:#1a1a2e;text-decoration:none;font-weight:bold;font-size:16px;padding:14px 36px;border-radius:6px;\">Download the Free Guide</a>\n    </p>\n    <p>If things change down the road, my door is always open.</p>\n    <p>Have a great rest of your day.</p>\n    <p style=\"margin:0 0 4px;\">Cheers,</p>\n    <p style=\"margin:0;font-weight:bold;color:#1a1a2e;\">Anthony</p>\n    <p style=\"margin:0;color:#4dd0e1;font-weight:600;\">Veteran Vectors</p>\n  </div>\n  <div style=\"background:#1a1a2e;padding:20px;text-align:center;border-radius:0 0 8px 8px;\">\n    <p style=\"margin:0;color:#888;font-size:12px;\">© 2026 Veteran Vectors. All rights reserved.</p>\n  </div>\n</div>",
        "options": {}
      },
      "id": "step5c-node-10b",
      "name": "Send Cancellation Email + Lead Magnet",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [910, 660],
      "credentials": {
        "gmailOAuth2": {
          "id": "r13jnGsjwNOqcBvt",
          "name": "VV Gmail account"
        }
      },
      "notes": "Sends cancellation email with free automation guide (lead magnet) when disapproved."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.calendly.com/scheduled_events/{{ $('Approval Webhook').item.json.query.event_uuid }}/cancellation",
        "authentication": "genericCredentialType",
        "genericAuthType": "oAuth2Api",
        "sendBody": true,
