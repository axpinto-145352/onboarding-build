        "options": {}
      },
      "id": "step5c-node-9a",
      "name": "Find Contact (Approve)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [690, 520]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://api.notion.com/v1/pages/{{ $json.results[0].id }}",
        "authentication": "genericCredentialType",
