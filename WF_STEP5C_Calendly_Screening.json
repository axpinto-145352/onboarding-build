        "jsonBody": "={ \"reason\": \"Based on your responses, we're not the right fit at this time. We've sent you a free guide with valuable automation resources.\" }",
        "options": {}
      },
      "id": "step5c-node-11b",
      "name": "Cancel Calendly Event",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [910, 820],
      "credentials": {
        "oAuth2Api": {
          "id": "uFXaP32GB3oPzqwu",
          "name": "VV - Calendly"
        }
      },
      "onError": "continueErrorOutput",
      "notes": "Cancels the Calendly event when Anthony disapproves the lead."
