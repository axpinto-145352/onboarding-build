      "name": "SOW Contract Form",
      "type": "n8n-nodes-base.formTrigger",
      "typeVersion": 2,
      "position": [250, 300],
      "webhookId": "sow-contract-form",
      "notes": "Form for Anthony to submit new client contract details. WF5 handles SOW creation and Stripe setup only. WF6 handles invoice sending after signing. WF7 handles welcome email after payment."
