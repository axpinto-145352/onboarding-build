    {
      "parameters": {
        "jsCode": "const endDateStr = $('SOW Contract Form').first().json.Project_End_Date;\nconst endDate = new Date(endDateStr);\n// First of next full month after project end date\n// e.g., if project ends April 5th, retainer starts May 1st\nconst retainerStart = new Date(endDate.getFullYear(), endDate.getMonth() + 1, 1);\nconst billingAnchorTimestamp = Math.floor(retainerStart.getTime() / 1000);\nreturn [{ json: {\n  retainer_start_date: retainerStart.toISOString(),\n  billing_cycle_anchor: billingAnchorTimestamp,\n  price_id: $json.id\n}}];"
      },
      "id": "wf5-node-20",
      "name": "Calculate Retainer Start Date",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2010, 650],
      "notes": "Calculates the retainer start date as the 1st of the next full month after Project_End_Date. E.g., project ends April 5th → retainer starts May 1st."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.stripe.com/v1/subscriptions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "stripeApi",
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {
          "parameters": [
            {
              "name": "customer",
              "value": "={{ $('Stripe: Create Customer').item.json.id }}"
            },
            {
              "name": "items[0][price]",
              "value": "={{ $json.price_id }}"
            },
            {
              "name": "billing_cycle_anchor",
              "value": "={{ $json.billing_cycle_anchor }}"
            },
            {
              "name": "proration_behavior",
              "value": "none"
            },
            {
