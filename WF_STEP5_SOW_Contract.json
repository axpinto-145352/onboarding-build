    {
      "parameters": {
        "jsCode": "const binaryData = $input.first().binary?.data;\nlet proposalText = '';\nif (binaryData) {\n  proposalText = Buffer.from(binaryData.data, 'base64').toString('utf-8').substring(0, 10000);\n}\nreturn [{ json: { proposal_text: proposalText } }];"
      },
