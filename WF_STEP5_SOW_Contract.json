    {
      "parameters": {
        "jsCode": "const url = $('SOW Contract Form').first().json.Proposal_Google_Drive_URL || '';\nconst match = url.match(/\\/d\\/([a-zA-Z0-9_-]+)/);\nconst fileId = match ? match[1] : '';\nreturn [{ json: { proposal_file_id: fileId } }];"
      },
      "id": "wf5-node-3",
      "name": "Extract Proposal File ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [690, 300],
      "notes": "Parses the Google Drive URL to extract the file ID for downloading the proposal PDF."
    },
    {
      "parameters": {
        "operation": "download",
        "fileId": {
          "__rl": true,
          "value": "={{ $json.proposal_file_id }}",
          "mode": "id"
        },
        "options": {}
      },
      "id": "wf5-node-4",
      "name": "Download Proposal PDF",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [910, 300],
      "notes": "Downloads the proposal PDF from Google Drive using the extracted file ID."
    },
    {
      "parameters": {
        "jsCode": "// Extract text content from the downloaded PDF binary\nconst binaryData = $input.first().binary?.data;\nlet proposalText = '';\nif (binaryData) {\n  proposalText = Buffer.from(binaryData.data, 'base64').toString('utf-8').substring(0, 10000);\n}\n// The form fields already have the key details, so the proposal is supplementary\nreturn [{ json: { proposal_text: proposalText } }];"
      },
      "id": "wf5-node-5",
      "name": "Extract Proposal Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1130, 300],
      "notes": "Extracts raw text from the proposal PDF binary data. This text is sent to Claude for structured extraction."
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "claude-sonnet-4-20250514",
          "mode": "id"
        },
        "messages": {
          "values": [
            {
              "content": "=You are a business analyst. Extract key details from this proposal text. Confirm or supplement the following form data:\n\nProject Name: {{ $('SOW Contract Form').first().json.Project_Name }}\nProject Scope: {{ $('SOW Contract Form').first().json.Project_Scope }}\nTimeline: {{ $('SOW Contract Form').first().json.Project_Start_Date }} to {{ $('SOW Contract Form').first().json.Project_End_Date }}\nTotal Cost: {{ $('SOW Contract Form').first().json.Total_Project_Cost }}\n\nProposal text:\n{{ $json.proposal_text }}\n\nReturn a JSON object with these fields:\n- confirmed_scope: the project scope (confirmed or enhanced from proposal)\n- deliverables: array of key deliverables found in the proposal\n- timeline_notes: any timeline details from the proposal\n- pricing_notes: any pricing details or payment terms from the proposal\n- additional_notes: anything else relevant not captured above\n\nReturn ONLY valid JSON, no markdown fences."
            }
          ]
        },
        "options": {
          "maxTokensToSample": 1024
        }
      },
      "id": "wf5-node-6",
      "name": "Claude: Extract Proposal Details",
      "type": "@n8n/n8n-nodes-langchain.anthropic",
      "typeVersion": 1,
      "position": [1350, 300],
      "credentials": {
        "anthropicApi": {
          "id": "au1c518sMzUt89ul",
          "name": "VV Claude"
        }
      },
      "notes": "Sends the extracted proposal text to Claude to confirm/extract structured project details (scope, deliverables, timeline, pricing). Supplements form data."
    },
