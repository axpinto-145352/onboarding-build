    {
      "parameters": {
        "jsCode": "const endDateStr = $('SOW Contract Form').first().json.Project_End_Date;\nconst endDate = new Date(endDateStr);\nconst retainerStart = new Date(endDate.getFullYear(), endDate.getMonth() + 1, 1);\nconst billingAnchorTimestamp = Math.floor(retainerStart.getTime() / 1000);\nreturn [{ json: {\n  retainer_start_date: retainerStart.toISOString(),\n  billing_cycle_anchor: billingAnchorTimestamp,\n  price_id: $json.id\n}}];"
      },
      "id": "wf5-node-20",
      "name": "Calculate Retainer Start Date",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2010, 650]
    },
