            { "fieldLabel": "Retainer_For_Invoice", "placeholder": "$200" },
            { "fieldLabel": "Compliance_Terms", "placeholder": "HIPAA, SOC2, etc." },
            { "fieldLabel": "Contract_Length", "placeholder": "6 months" },
            { "fieldLabel": "Notion_Contact_ID", "requiredField": true }
          ]
        },
        "options": { "buttonLabel": "Generate Contract" }
      },
