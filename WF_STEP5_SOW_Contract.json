        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {
          "parameters": [
            { "name": "customer", "value": "={{ $('Stripe: Create Customer').item.json.id }}" },
            { "name": "items[0][price]", "value": "={{ $json.price_id }}" },
            { "name": "billing_cycle_anchor", "value": "={{ $json.billing_cycle_anchor }}" },
            { "name": "proration_behavior", "value": "none" },
            { "name": "collection_method", "value": "send_invoice" },
            { "name": "days_until_due", "value": "3" },
            { "name": "pause_collection[behavior]", "value": "void" }
          ]
        },
        "options": {}
