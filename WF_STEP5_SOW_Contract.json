        "jsCode": "// Parse the Stripe webhook payload to confirm payment\nconst webhookData = $json.body || $json;\nconst eventType = webhookData.type || '';\nconst invoice = webhookData.data?.object || {};\nconst isPaid = invoice.status === 'paid' || eventType === 'invoice.paid';\nconst amountPaid = invoice.amount_paid || 0;\n\nreturn [{ json: {\n  payment_verified: isPaid,\n  invoice_id: invoice.id || '',\n  amount_paid_cents: amountPaid,\n  customer_id: invoice.customer || '',\n  payment_received_at: new Date().toISOString()\n}}];"
