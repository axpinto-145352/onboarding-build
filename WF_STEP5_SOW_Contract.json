      "position": [250, 300],
      "webhookId": "sow-contract-form",
      "notes": "Form for Anthony to submit new client contract details. Includes Proposal_Google_Drive_URL for extracting proposal details, plus all project scope, financial terms, compliance requirements, and Notion contact ID."
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "calc-retainer-cents",
              "name": "retainer_cents",
              "value": "={{ Math.round(Number(String($json.Retainer_Cost || '0').replace(/[^0-9.]/g, '')) * 100) }}",
              "type": "string"
