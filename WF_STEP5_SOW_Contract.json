      "notes": "Pauses the workflow and waits for SignWell's document.completed webhook callback. Resumes when all parties have signed the SOW."
    },
    {
      "parameters": {
        "jsCode": "// Parse the SignWell webhook payload to verify all parties signed\nconst webhookData = $json.body || $json;\nconst documentStatus = webhookData.status || webhookData.document?.status || '';\nconst recipients = webhookData.recipients || webhookData.document?.recipients || [];\n\nlet allSigned = true;\nfor (const recipient of recipients) {\n  if (recipient.status !== 'signed' && recipient.status !== 'completed') {\n    allSigned = false;\n    break;\n  }\n}\n\nconst isCompleted = documentStatus === 'completed' || documentStatus === 'signed';\n\nreturn [{ json: {\n  all_signatures_verified: allSigned && isCompleted,\n  document_status: documentStatus,\n  signer_count: recipients.length,\n  webhook_received_at: new Date().toISOString()\n}}];"
      },
