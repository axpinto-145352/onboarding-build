      "parameters": {
        "jsCode": "// Get contact page ID from either the found contact or the newly created one\nlet contactId = '';\ntry {\n  const found = $('Contact Exists?').first().json;\n  if (found && found.id) {\n    contactId = found.id;\n  }\n} catch(e) {}\n\nif (!contactId) {\n  try {\n    const created = $('Create Contact if New').first().json;\n    if (created && created.id) {\n      contactId = created.id;\n    }\n  } catch(e) {}\n}\n\nconst d = $('Consolidate Screening Data').first().json;\nreturn [{ json: { ...d, notion_contact_id: contactId } }];"
      },
