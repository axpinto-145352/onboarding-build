            },
            {
              "key": "Responded|checkbox",
              "checkboxValue": true
            },
            {
              "key": "Last Contact Date|date",
              "dateValue": "={{ $now.toISO() }}",
              "includeTime": true
            }
          ]
        },
        "options": {}
      }
    },
    {
      "parameters": {
        "amount": 0.5
      },
      "id": "step3c-node-17",
      "name": "Rate Limit Delay",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        3550,
        420
      ],
      "webhookId": "step3c-rate-limit"
    }
  ],
