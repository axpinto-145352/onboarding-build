{
  "name": "Lead Gen WF3C — Calendly Discovery Call Screening",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "calendly-discovery-screening",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "step3c-node-1",
      "name": "Calendly Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        250,
        500
      ],
      "webhookId": "calendly-discovery-screening",
      "notes": "Receives Calendly invitee.created webhooks for 'Veteran Vectors - Discovery Call' events. Responds immediately with 200."
    },
    {
      "parameters": {
        "jsCode": "const payload = $json.body || $json;\nconst eventPayload = payload.payload || {};\nconst event = eventPayload.event || {};\nconst invitee = eventPayload.invitee || {};\n\nconst eventUri = event.uri || eventPayload.event || '';\nconst eventUuid = eventUri ? eventUri.split('/').pop() : '';\nconst eventName = event.name || eventPayload.event_type?.name || 'Discovery Call';\nconst startTime = event.start_time || '';\n\nconst inviteeName = invitee.name || '';\nconst inviteeEmail = invitee.email || '';\n\nconst qAndA = invitee.questions_and_answers || [];\n\nlet q1_decision_maker = '';\nlet q2_budget = '';\nlet q3_employees = '';\nlet q4_processes = '';\nlet q5_current_tools = '';\nlet q6_phone = '';\n\nfor (const qa of qAndA) {\n  const q = (qa.question || '').toLowerCase();\n  const a = qa.answer || '';\n\n  if (q.includes('business owner') || q.includes('decision maker')) {\n    q1_decision_maker = a;\n  } else if (q.includes('$2,000') || q.includes('2,000') || q.includes('budget')) {\n    q2_budget = a;\n  } else if (q.includes('how many employees')) {\n    q3_employees = a;\n  } else if (q.includes('processes are you looking to automate') || q.includes('specific processes')) {\n    q4_processes = a;\n  } else if (q.includes('currently handling') || q.includes('tools, processes')) {\n    q5_current_tools = a;\n  } else if (q.includes('phone number')) {\n    q6_phone = a;\n  }\n}\n\nreturn [{\n  json: {\n    event_uri: eventUri,\n    event_uuid: eventUuid,\n    event_name: eventName,\n    start_time: startTime,\n    invitee_name: inviteeName,\n    invitee_email: inviteeEmail,\n    q1_decision_maker,\n    q2_budget,\n    q3_employees,\n    q4_processes,\n    q5_current_tools,\n    q6_phone\n  }\n}];"
      },
      "id": "step3c-node-2",
      "name": "Extract Event + Invitee Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        500
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $json;\nconst q1Fail = (d.q1_decision_maker || '').toLowerCase() === 'no';\nconst q2Fail = (d.q2_budget || '').toLowerCase().includes('not quite yet');\nconst q3Fail = ['1-5', '6-10'].includes(d.q3_employees || '');\nconst isPotentialDecline = q1Fail && q2Fail && q3Fail;\nreturn [{ json: { ...d, is_potential_decline: isPotentialDecline, q1_fail: q1Fail, q2_fail: q2Fail, q3_fail: q3Fail } }];"
      },
      "id": "step3c-node-3",
      "name": "Check Decline Criteria",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        750,
        500
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "condition-decline",
              "leftValue": "={{ $json.is_potential_decline }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ]
        },
        "looseTypeValidation": true,
        "options": {}
      },
      "id": "step3c-node-4",
      "name": "Potential Decline?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1000,
        500
      ]
    },
    {
      "parameters": {
        "sendTo": "anthony@veteranvectors.io",
        "subject": "=⚠️ Discovery Call Screening: {{ $json.invitee_name }} — Potential Decline",
        "emailType": "html",
        "message": "=<div style=\"font-family: Arial, sans-serif; max-width: 600px;\">\n<h2 style=\"color: #d35400;\">⚠️ Discovery Call Screening — Potential Decline</h2>\n<hr>\n<table style=\"width:100%; border-collapse:collapse;\">\n<tr><td style=\"padding:6px 12px; font-weight:bold;\">Name:</td><td style=\"padding:6px 12px;\">{{ $json.invitee_name }}</td></tr>\n<tr><td style=\"padding:6px 12px; font-weight:bold;\">Email:</td><td style=\"padding:6px 12px;\">{{ $json.invitee_email }}</td></tr>\n<tr><td style=\"padding:6px 12px; font-weight:bold;\">Event:</td><td style=\"padding:6px 12px;\">{{ $json.event_name }}</td></tr>\n<tr><td style=\"padding:6px 12px; font-weight:bold;\">Scheduled:</td><td style=\"padding:6px 12px;\">{{ $json.start_time }}</td></tr>\n</table>\n<h3 style=\"margin-top:20px;\">Screening Answers</h3>\n<table style=\"width:100%; border-collapse:collapse; border:1px solid #ddd;\">\n<tr style=\"background:#f8f8f8;\"><td style=\"padding:8px; font-weight:bold; border:1px solid #ddd;\">Q1: Business Owner / Decision Maker?</td><td style=\"padding:8px; border:1px solid #ddd; color:{{ $json.q1_fail ? '#c0392b' : '#27ae60' }};\">{{ $json.q1_decision_maker || 'No answer' }} {{ $json.q1_fail ? '❌' : '✅' }}</td></tr>\n<tr><td style=\"padding:8px; font-weight:bold; border:1px solid #ddd;\">Q2: Budget ($2,000+ OK)?</td><td style=\"padding:8px; border:1px solid #ddd; color:{{ $json.q2_fail ? '#c0392b' : '#27ae60' }};\">{{ $json.q2_budget || 'No answer' }} {{ $json.q2_fail ? '❌' : '✅' }}</td></tr>\n<tr style=\"background:#f8f8f8;\"><td style=\"padding:8px; font-weight:bold; border:1px solid #ddd;\">Q3: Employees</td><td style=\"padding:8px; border:1px solid #ddd; color:{{ $json.q3_fail ? '#c0392b' : '#27ae60' }};\">{{ $json.q3_employees || 'No answer' }} {{ $json.q3_fail ? '❌' : '✅' }}</td></tr>\n<tr><td style=\"padding:8px; font-weight:bold; border:1px solid #ddd;\">Q4: Processes to Automate</td><td style=\"padding:8px; border:1px solid #ddd;\">{{ $json.q4_processes || 'No answer' }}</td></tr>\n<tr style=\"background:#f8f8f8;\"><td style=\"padding:8px; font-weight:bold; border:1px solid #ddd;\">Q5: Current Tools/Processes</td><td style=\"padding:8px; border:1px solid #ddd;\">{{ $json.q5_current_tools || 'No answer' }}</td></tr>\n<tr><td style=\"padding:8px; font-weight:bold; border:1px solid #ddd;\">Q6: Phone Number</td><td style=\"padding:8px; border:1px solid #ddd;\">{{ $json.q6_phone || 'No answer' }}</td></tr>\n</table>\n<p style=\"margin-top:20px; color:#c0392b; font-weight:bold;\">All 3 decline criteria met. Action required:</p>\n<div style=\"margin-top:16px; text-align:center;\">\n<a href=\"{{ $execution.resumeUrl }}?action=approve&event_uuid={{ $json.event_uuid }}&invitee_email={{ encodeURIComponent($json.invitee_email) }}\" style=\"display:inline-block; padding:12px 32px; background:#27ae60; color:#fff; text-decoration:none; border-radius:6px; font-size:16px; margin-right:12px;\">✅ Approve — Keep Call</a>\n<a href=\"{{ $execution.resumeUrl }}?action=disapprove&event_uuid={{ $json.event_uuid }}&invitee_email={{ encodeURIComponent($json.invitee_email) }}\" style=\"display:inline-block; padding:12px 32px; background:#c0392b; color:#fff; text-decoration:none; border-radius:6px; font-size:16px;\">❌ Disapprove — Cancel Call</a>\n</div>\n</div>",
        "options": {}
      },
